{
  "name": "porthole-root",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/porthole",
    "packages/porthole-client"
  ],
  "scripts": {
    "build": "npm run build:ts -w portholejs && npm run build -w porthole-client && npm run copy-package-assets -w portholejs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "typecheck": "tsc --build",
    "postinstall": "node packages/porthole/scripts/download-scrcpy-server.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
