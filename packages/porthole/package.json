{
  "name": "portholejs",
  "version": "0.2.1",
  "description": "A window into your Android emulator — stream and control AVDs from the browser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "porthole": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:ts && npm run copy-package-assets",
    "build:ts": "tsc",
    "copy-package-assets": "node scripts/copy-package-assets.mjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/download-scrcpy-server.mjs",
    "prepublishOnly": "npm run build --prefix ../.."
  },
  "keywords": [
    "android",
    "emulator",
    "android-tv",
    "scrcpy",
    "adb",
    "avd",
    "mcp",
    "claude"
  ],
  "license": "Apache-2.0",
  "author": "Giovanni Laquidara (https://github.com/giolaq)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giolaq/porthole.git"
  },
  "homepage": "https://github.com/giolaq/porthole#readme",
  "bugs": {
    "url": "https://github.com/giolaq/porthole/issues"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "scripts/download-scrcpy-server.mjs",
    "client-dist/",
    "skills/"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-scrcpy": "^2.3.2",
    "@yume-chan/adb-server-node-tcp": "^2.5.2",
    "@yume-chan/scrcpy": "^2.3.0",
    "@yume-chan/stream-extra": "^2.5.3",
    "commander": "^15.0.0",
    "jpeg-js": "^0.4.4",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1"
  }
}
