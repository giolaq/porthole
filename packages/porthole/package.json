{
  "name": "portholejs",
  "version": "0.0.1",
  "description": "A window into your Android emulator — stream and control AVDs from the browser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "porthole": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-package-assets.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "android",
    "emulator",
    "scrcpy",
    "mcp"
  ],
  "license": "MIT",
  "files": [
    "dist/",
    "!dist/__tests__/",
    "assets/scrcpy-server",
    "client-dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-scrcpy": "^2.3.2",
    "@yume-chan/adb-server-node-tcp": "^2.5.2",
    "@yume-chan/scrcpy": "^2.3.0",
    "@yume-chan/stream-extra": "^2.5.3",
    "commander": "^14.0.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1"
  }
}
